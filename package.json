{
  "name": "vibe-sender",
  "productName": "Mentor Vault",
  "description": "Local teacher and mentor records database.",
  "author": "Luofaiz",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "main": "electron/main.mjs",
  "updateManifestUrl": "https://gcore.jsdelivr.net/gh/Luofaiz/mentor-vault-releases@main/latest.json",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:desktop": "electron .",
    "dev:desktop:test": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-desktop-dev.ps1",
    "build": "vite build",
    "build:web": "vite build",
    "build:desktop:installer": "npm run build && electron-builder --win nsis --x64",
    "build:desktop:portable": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-electron-portable.ps1",
    "desktop": "electron .",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.luofaiz.mentorvault",
    "productName": "Mentor Vault",
    "directories": {
      "output": "release/installer"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "node_modules/nodemailer/**/*"
    ],
    "asar": true,
    "extraMetadata": {
      "updateManifestUrl": "https://gcore.jsdelivr.net/gh/Luofaiz/mentor-vault-releases@main/latest.json"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MentorVaultSetup.${ext}"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mentor Vault",
      "deleteAppDataOnUninstall": false
    }
  }
}
